<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STARTUP BITE"
        android:textColor="#FF666666"
        android:textSize="9sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.15" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="10dp"
        android:background="#FF1A1A1A" />

    <TextView
        android:id="@+id/widget_term_ko"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="오늘의 용어"
        android:textColor="#FFFFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_term_en"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="TODAY'S TERM"
        android:textColor="#FF666666"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.1" />

    <TextView
        android:id="@+id/widget_definition"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:text="탭하여 앱에서 학습하기"
        android:textColor="#FF999999"
        android:textSize="12sp"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/btn_complete"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✓ 이해했어요"
            android:textColor="#FF34D399"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="@drawable/widget_btn_complete" />

        <View
            android:layout_width="6dp"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="다음 용어 →"
            android:textColor="#FF60A5FA"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="@drawable/widget_btn_next" />

    </LinearLayout>

</LinearLayout>
